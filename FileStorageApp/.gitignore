## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# Thư mục Rác khi Build (ĐÃ ĐƯỢC CHẶN GIÚP BẠN)
[Bb]in/
[Oo]bj/

# Rác của phần mềm Visual Studio IDE
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# Rác Dữ liệu người dùng (Hồ sơ cứng)
StorageTemp/
*.db
*.sqlite
*.sqlite3

# Rác thư viện bên thứ 3 tải về (NuGet)
packages/
*.nupkg

# Rác hệ điều hành
.DS_Store
Thumbs.db
